# Included by scripts/configure-git.ps1
# Put your personal overrides in ~/.gitconfig (global) or edit here.

[core]
  editor = code --wait

[diff]
  tool = vscode
[difftool "vscode"]
  cmd = code --wait --diff $LOCAL $REMOTE

[merge]
  tool = vscode
[mergetool "vscode"]
  cmd = code --wait $MERGED

[alias]
  st = status
  co = checkout
  br = branch
  ci = commit
  last = log -1 --stat

[credential]
  helper = manager
